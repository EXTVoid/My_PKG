#!/bin/sh
# Copyright (c) 2023 LENAR

arg_imei="$2"
script_name="$(basename "$0")"

show_usage() {
    cat <<EOF
Usage: $script_name <Method> [IMEI]

Method
  delete               - Delete current IMEI
  write                - Write new IMEI
  update               - Update current IMEI
  read                 - Read current IMEI
  check                - Check current IMEI

Examples
  $script_name w 123456789012345
  $script_name c
EOF
}


header() {
    echo -e "--[      IMEI Change      ]--\n"
}

normalize() {
    echo "$1" | tr 'A-Z' 'a-z'
}

error_exit() {
    echo "Error: $1" >&2
    exit 1
}

imei_check() {
    check_imei=$(at_cmd "AT*MRD_IMEI?" | sed -n 's/^\*MRD_IMEI://p' | xargs)
}

prod_enable() {
    if ! at_exec "serial_atcmd AT*PROD=2" &> /dev/null; then
        error_exit "Failed to enable production mode."
    fi
}

prod_disable() {
    if ! at_exec "serial_atcmd AT*PROD=0" &> /dev/null; then
    error_exit "Failed to disable production mode."
    fi
}

reboot_cp() {
    if at_exec "reboot" >/dev/null 2>&1; then
        echo "Restarting module..."
    else
        error_exit "Failed to restart module. Restart device manually."
    fi
}

delete_imei() {
    prod_enable
    if ! output=$(at_cmd "AT*MRD_IMEI=D"); then
        error_exit "Failed to execute Delete command."
    else
        imei_check
        if ! [ -n "$check_imei" ]; then
            header
            echo "IMEI successfully deleted."
            prod_disable
        else
            error_exit "Failed to delete IMEI."
        fi
    fi
}

write_update_imei() {
    imei_check
    prod_enable
    case "$arg_method" in
        u) action="Update" ;;
        w) action="Write" ;;
    esac
    [ "$check_imei" = "$arg_imei" ] && error_exit "$action skipped because IMEI is the same."
    if ! expr "$arg_imei" : '[0-9]\{15\}$' &> /dev/null; then
        error_exit "IMEI must be 15 numeric digits."
    fi
    if ! output=$(at_cmd "AT*MRD_IMEI=$arg_method,0101,01JAN1970,$arg_imei"); then
        error_exit "Failed to execute $(normalize "$action") command."
    else
        if [ "$check_imei" = "$arg_imei" ]; then
            header
            echo "$action IMEI completed successfully."
            prod_disable && reboot_cp
        else
            error_exit "Failed to $(normalize "$action") IMEI."
        fi
    fi
}

read_check_imei() {
    imei_check
    read_imei=$(at_cmd "AT*MRD_IMEI=R" | sed -n 's/^\*MRD_IMEI://p' | xargs)
    case "$arg_method" in
        r) result="$read_imei" ;;
        c) result="$check_imei" ;;
    esac
    if [ -n "$result" ]; then
        header
        echo "IMEI: $result"
    else
        error_exit "Failed to read IMEI or no IMEI found."
    fi
}

main() {
    if [ $# -eq 0 ]; then
        error_exit "No command specified. Use '$script_name check' to check current IMEI."
    fi
    case "$(normalize "$1")" in
        h|help) show_usage ;;
        d|delete) delete_imei ;;
        w|write) arg_method="w"; write_update_imei ;;
        u|update) arg_method="u"; write_update_imei ;;
        r|read) arg_method="r"; read_check_imei ;;
        c|check) arg_method="c"; read_check_imei ;;
        *) error_exit "Invalid command '$1'. Use '$script_name help' for more details." ;;
    esac
}

main "$@"
